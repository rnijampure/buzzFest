generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS (clean + type-safe)
//

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  QUEUED
  IN_PROGRESS
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

//
// MODELS
//
model Baker {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  images      String[]
  specialty   String
  experience  String
  location    String
  description String   @db.Text
  rating      Float    @default(5.0)

  // Relations
  products Product[]
  tasks    Task[] // ✅ ADD THIS

  createdAt DateTime @default(now())

  @@index([slug])
}

model ProductVariant {
  id    String  @id @default(cuid())
  name  String
  price Decimal @db.Decimal(10, 2)
  stock Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)
  category    String[]
  images      String[]
  stock       Int      @default(0)
  starRating  Float    @default(0.0)
  isFeatured  Boolean  @default(false)
  isVeg       Boolean  @default(true)

  creatorSlug String
  baker       Baker  @relation(fields: [creatorSlug], references: [slug])

  variants   ProductVariant[] // ✅ you added this
  orderItems OrderItem[] // ✅ ADD THIS LINE (FIX)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id            String  @id @default(cuid())
  orderNumber   Int     @unique
  customerEmail String
  customerName  String?

  totalAmount Decimal     @db.Decimal(10, 2)
  currency    String      @default("INR")
  status      OrderStatus @default(PENDING)

  // Relations
  items OrderItem[]
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Int    @default(1)

  // Snapshot fields (CRITICAL)
  priceAtPurchase Decimal @db.Decimal(10, 2)
  productName     String
  productImage    String?

  // Relations
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Meta
  bakerSlug String?

  @@index([orderId])
  @@index([productId])
}

model Task {
  id       String     @id @default(cuid())
  title    String
  priority Priority   @default(MEDIUM)
  status   TaskStatus @default(QUEUED)

  // Relation → Order
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  notes          String
  dueDate        DateTime
  isDelayed      Boolean  @default(false)
  delayedUntil   DateTime
  // Optional relation → Baker
  assignedToSlug String?
  assignedTo     Baker?   @relation(fields: [assignedToSlug], references: [slug])

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([assignedToSlug])
}
